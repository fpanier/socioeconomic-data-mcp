# Copy to .env and fill in. Loaded by your process manager / shell, NOT by the app.

# Transport: "stdio" (local dev) or "streamable-http" (public claude.ai connector).
MCP_TRANSPORT=stdio

# HTTP bind (streamable-http only). Behind a reverse proxy keep 127.0.0.1.
MCP_HOST=127.0.0.1
MCP_PORT=8000

# Public hostname the reverse proxy serves under. REQUIRED behind a proxy or the MCP
# transport rejects requests whose Host isn't allow-listed (HTTP 421).
MCP_PUBLIC_HOST=
MCP_ALLOWED_ORIGINS=

# --- Auth: choose ONE for streamable-http ---
# A) OAuth (claude.ai web/mobile): set a browser sign-in password. The server then runs
#    an OAuth 2.1 layer (dynamic registration + PKCE).
MCP_OAUTH_PASSWORD=
# B) Static bearer (Claude Code/Desktop, scripts) — also accepted alongside OAuth.
MCP_AUTH_TOKEN=
# C) Fully public (no auth). Required to run open; protect with a proxy rate limit.
MCP_ALLOW_PUBLIC=

# Writable dir for OAuth state persistence (clients/tokens) across restarts.
MCP_STATE_DIR=

# FRED needs a free key (https://fredaccount.stlouisfed.org). On a public instance,
# cap total daily FRED calls to protect the shared key (0/unset = no cap).
MCP_FRED_API_KEY=
MCP_FRED_DAILY_CAP=500

# Email notification on each new OAuth registration (requires MCP_OAUTH_PASSWORD mode).
# No-op unless MCP_ALERT_EMAIL plus a transport is set. Recipient:
MCP_ALERT_EMAIL=
# Transport A — Brevo transactional API (preferred if set); sender from NEWSLETTER_SENDER_EMAIL.
BREVO_API_KEY=
NEWSLETTER_SENDER_EMAIL=
NEWSLETTER_SENDER_NAME=
# Transport B — plain SMTP relay (587 = STARTTLS, 465 = implicit TLS).
MCP_SMTP_HOST=
MCP_SMTP_PORT=587
MCP_SMTP_USER=
MCP_SMTP_PASS=
MCP_SMTP_FROM=
